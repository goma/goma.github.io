---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Goma Contact Information">
  <section class="page-hero compact">
    <p class="eyebrow">Contact</p>
    <h1>Project contact and support channels</h1>
    <p>
      For usage questions, start with GitHub Discussions. For open source project
      contact, email the project maintainer address.
    </p>
  </section>

  <section class="content-grid">
    <article class="prose callout">
      <h2>Questions and Answers</h2>
      <p>All general usage questions should be a GitHub Discussion.</p>
      <a class="button primary" href="https://github.com/goma/goma/discussions">Open Discussions</a>
    </article>
    <article class="prose callout">
      <h2>Open Source Contact</h2>
      <p>Primary open source contact: Weston Ortiz</p>
      <a class="button primary" href="mailto:contact@gomafem.com">contact@gomafem.com</a>
    </article>
  </section>
</BaseLayout>
